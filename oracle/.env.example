# ──────────────────────────────────────────────────────────────────────────────
# FlowGuard Oracle — Environment Configuration
# ──────────────────────────────────────────────────────────────────────────────
# SECURITY: This file is for LOCAL DEVELOPMENT only.
#   • NEVER commit this to version control.
#   • In production use a secrets manager (Vault, AWS Secrets Manager, GCP Secret Manager).
#   • Add ".env" to your .gitignore immediately.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Stellar / Soroban ───────────────────────────────────────────────────────

# The Soroban RPC endpoint to submit transactions to.
# Testnet: https://soroban-testnet.stellar.org
# Mainnet: Use your own Horizon/RPC instance or a provider like Alchemy, Blockdaemon.
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase — must match the network your contract is deployed on.
SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# The deployed FlowGuard contract ID (C... address).
FLOWGUARD_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAD2KM

# The secret key of the account authorized to call release_milestone.
# This is the CLIENT wallet whose authorization the contract checks.
# ⚠️  NEVER share this key. Use a secrets manager in production.
ORACLE_SECRET_KEY=SAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# ─── GitHub Webhook ──────────────────────────────────────────────────────────

# The webhook secret you configured in your GitHub repository settings.
# Used to verify the X-Hub-Signature-256 header on incoming requests.
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# ─── Milestone Mapping ───────────────────────────────────────────────────────

# Map GitHub branch names to milestone IDs (0-indexed).
# Format: JSON object where keys are branch names and values are milestone IDs.
# The oracle will release the corresponding milestone when a PR targeting that
# branch is merged.
MILESTONE_MAP={"main":0,"milestone-1":0,"milestone-2":1,"milestone-3":2}

# ─── Server ──────────────────────────────────────────────────────────────────

PORT=3000
LOG_LEVEL=info
